# Server
PORT=8080
NODE_ENV=development

# Auth
JWT_SECRET=replace-with-a-long-random-string-in-production
STAFF_PASSCODE=replace-with-a-real-per-deployment-passcode

# CORS — comma-separated allowed origins. Required in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Payments (Phase 2 — Stripe Connect; unused while PAYMENT_PROVIDER=SIMULATED)
STRIPE_SECRET_KEY=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/feast
