{
  "expo": {
    "name": "Let's Feast",
    "slug": "feast-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "feastcustomer",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F7F1E6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.feast.customer"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F1E6"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.feast.customer",
          "enableGooglePay": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
